---
// we can import fonts here, after installing them via Fontsource
// see https://fontsource.org/docs/installation for instructions
import "@fontsource/karla";
---

<style is:global>
  /* We can use this style tag to set up colors, fonts, etc. */

  @import url('https://fonts.googleapis.com/css2?family=Caladea:ital,wght@0,400;0,700;1,400;1,700&display=swap');

  :root {
    --color-background: #F1F1E0;
    --color-text: black;
    --color-accent: rgb(0, 200, 255);
    --color-focus-ring: rgb(255, 0, 255);

    --font-body: "Caladea", sans-serif;
    --font-headings: "Caladea", sans-serif;

    font-size: 18px;

    /* These sizes are used by the Container component to set up the page container */
    --size-page-width: 800px;
    --size-page-padding: 1rem;
  }

  /* We can also apply these colors as a default */
  body {
    background-image: url("public/img/Whitewall.png");
    background-color: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-body);
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--color-accent);
  }

  /* default focus ring styles */
  *:focus-visible {
    outline: 3px solid var(--color-focus-ring);
  }
</style>
